  const expo = expos.find(x => x.id === id);
  if (!expo) return;
  const color = getColorByCode(expo.CouleurEXPO).light;
  const m    = getMontageRange(expo), dem = getDemontageRange(expo);
  const v    = fixDate(expo.vernissage), f  = fixDate(expo.finissage);
  const svcs = getServices(expo).join(', ');

  let equipeHtml = '';
  if (expo.Regisseur_AV)     equipeHtml += `<div><b>?? SPAV :</b> ${getPersonName(expo.Regisseur_AV)}</div>`;
  if (expo.Regisseur_AMT)    equipeHtml += `<div><b>?? AMT :</b> ${getPersonName(expo.Regisseur_AMT)}</div>`;
  if (expo.AMT_Lumiere)      equipeHtml += `<div><b>?? Lumi�re :</b> ${getPersonName(expo.AMT_Lumiere)}</div>`;
  if (expo.Regis_des_salles) equipeHtml += `<div><b>?? Salles :</b> ${getPersonName(expo.Regis_des_salles)}</div>`;
  if (!equipeHtml) equipeHtml = `<div><i>Aucun agent assign�</i></div>`;

  const tt = document.getElementById('tooltip');
  tt.innerHTML = `
    <b class="title" style="color:${color}">${expo.Nom_de_l_exposition || 'Sans nom'}</b>
    <div><b>?? Lieu :</b> ${getLieuName(expo.Musee)}</div>
    ${svcs ? `<div><b>??? Service(s) :</b> ${svcs}</div>` : ''}
    <hr style="border:0; border-top:1px solid #555; margin:6px 0;">
    ${equipeHtml}
    ${(!expo.Pret && m)
      ? `<hr style="border:0; border-top:1px solid #555; margin:6px 0;">
         <div><b>?? Montage :</b> ${fmtDate(m.start)} ? ${fmtDate(m.end)}</div>` : ''}
    <div><b>?? ${expo.Pret ? 'Pr�t' : 'Expo'} :</b>
      ${v ? fmtDate(v) + ' ? ' + fmtDate(f) : 'N/A'}</div>
    ${(!expo.Pret && dem)
      ? `<div><b>?? D�montage :</b> ${fmtDate(dem.start)} ? ${fmtDate(dem.end)}</div>` : ''}
  `;
  tt.classList.add('visible');
  const x = Math.min(e.clientX + 15, window.innerWidth - 335);
  tt.style.left = x + 'px';
  tt.style.top  = (e.clientY + 15) + 'px';
}
function hideTooltip() { document.getElementById('tooltip').classList.remove('visible'); }

