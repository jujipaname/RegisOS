// ==================== SAVE / DELETE ====================
function getRecordFromForm() {
  const checkedSvcs = Array.from(document.querySelectorAll('.fm-svc-cb:checked'))
    .map(cb => cb.value);

  const record = {
    Nom_de_l_exposition: document.getElementById('fm-nom').value,
    Service:     ['L', ...checkedSvcs],
    Pret:        document.getElementById('fm-pret').checked,
    CouleurEXPO: document.getElementById('ed-color').value
  };

    // Colonnes Reference() � Column IDs exacts sans accent
  const refFields = {
    Musee:            document.getElementById('fm-musee').value,
    Regisseur_AV:     document.getElementById('fm-av').value,
    Regisseur_AMT:    document.getElementById('fm-amt').value,
    AMT_Lumiere:      document.getElementById('fm-lumiere').value,  // sans accent
    Regis_des_salles: document.getElementById('fm-salles').value
  };
  Object.entries(refFields).forEach(([key, val]) => {
    const parsed = parseInt(val);
    record[key] = (!isNaN(parsed) && parsed > 0) ? parsed : 0;
  });

  // Dates � uniquement si renseign�es
  const dateFields = {
    vernissage:         document.getElementById('fm-v').value,
    finissage:          document.getElementById('fm-f').value,
    debut_date_montage: document.getElementById('fm-dm').value,
    fin_date_montage:   document.getElementById('fm-fdm').value
  };
  Object.entries(dateFields).forEach(([key, val]) => {
    if (val) record[key] = val;
  });

  return record;
}

async function saveExpo(id) {
  const record = getRecordFromForm();
  if (!record.Nom_de_l_exposition.trim()) {
    alert('Le nom de l\'exposition est obligatoire.');
    return;
  }
  try {
    if (id) {
      await grist.docApi.applyUserActions([['UpdateRecord', TABLE_EXPOS, id, record]]);
    } else {
      await grist.docApi.applyUserActions([['AddRecord', TABLE_EXPOS, null, record]]);
    }
    closeEdit();
  } catch(e) {
    alert('Erreur lors de l\'enregistrement : ' + e.message);
  }
}

async function deleteExpo(id) {
  if (!confirm('Supprimer cette exposition ? Cette action est irr�versible.')) return;
  try {
    await grist.docApi.applyUserActions([['RemoveRecord', TABLE_EXPOS, id]]);
    closeEdit();
  } catch(e) {
    alert('Erreur lors de la suppression : ' + e.message);
  }
}

// ==================== EXPORT ICS ====================
function exportICS() {
  const filtered = getFilteredExpos();
  const ics  = ['BEGIN:VCALENDAR','VERSION:2.0','PRODID:-//Planning Expos//FR','CALSCALE:GREGORIAN'];
  const fmtD = d => d.toISOString().replace(/-|:|\.\d+/g, '').substring(0, 8);

  filtered.forEach(expo => {
    const v = fixDate(expo.vernissage), f = fixDate(expo.finissage);
    if (v && f) {
      const fNext = new Date(f); fNext.setDate(fNext.getDate() + 1);
      ics.push('BEGIN:VEVENT',
        `DTSTART;VALUE=DATE:${fmtD(v)}`,
        `DTEND;VALUE=DATE:${fmtD(fNext)}`,
        `SUMMARY:${expo.Nom_de_l_exposition || 'Expo'}`,
        `LOCATION:${getLieuName(expo.Musee)}`,
        'END:VEVENT');
    }
  });
  ics.push('END:VCALENDAR');

  const a = document.createElement('a');
  a.href = URL.createObjectURL(new Blob([ics.join('\r\n')], { type: 'text/calendar' }));
  a.download = 'planning_expos.ics';
  a.click();
}

