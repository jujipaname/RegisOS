  } catch(e) {
    console.warn('Impossible de mettre � jour A_Affiche :', e.message);
  }

  populateFilters();
  render();
}

function toggleWorkload() {
  showWorkload = !showWorkload;
  localStorage.setItem('gantt_showWorkload', showWorkload);
  populateFilters();
  render();
}

// ==================== DATE HELPERS ====================
function daysBetween(a, b) { return Math.round((b - a) / 86400000); }

function isFerieGlobal(d) {
  return feries.some(f => {
    if (f.d.toDateString() !== d.toDateString()) return false;
    return !f.pays || f.pays === 0 ||
           (Array.isArray(f.pays) && f.pays.length === 0) ||
           String(f.pays).trim() === '';
  });
}

function getFerieForLieu(d, lieuId) {
  if (!lieuId || lieuId === 'PRET_GROUP') return null;
  const lieuPays = lieuxObj[lieuId] ? lieuxObj[lieuId].pays : null;
  if (!lieuPays) return null;
  return feries.find(f => {
    if (f.d.toDateString() !== d.toDateString()) return false;
    if (!f.pays || f.pays === 0 ||
        (Array.isArray(f.pays) && f.pays.length === 0) ||
        String(f.pays).trim() === '') return false;
    if (Array.isArray(f.pays))
      return f.pays.includes(Number(lieuPays)) || f.pays.includes(String(lieuPays));
    return String(f.pays) === String(lieuPays);
  });
}

function fmtDate(d) {
  if (!d) return ' ';
  return d.toLocaleDateString('fr-FR', { day: '2-digit', month: 'short', year: 'numeric' });
}

function getMontageRange(expo) {
  const v = fixDate(expo.vernissage), md = fixDate(expo.debut_date_montage);
  let s = md, e = v;
  if (!s && v) { s = new Date(v); s.setMonth(s.getMonth() - 1); }
  if (!e && s) { e = new Date(s); e.setMonth(e.getMonth() + 1); }
  return (s && e) ? { start: s, end: e } : null;
}

function getDemontageRange(expo) {
  const f = fixDate(expo.finissage), mf = fixDate(expo.fin_date_montage);
  let s = f, e = mf;
  if (!s && e) { s = new Date(e); s.setDate(s.getDate() - 7); }
  if (!e && s) { e = new Date(s); e.setDate(e.getDate() + 7); }
  return (s && e) ? { start: s, end: e } : null;
}

function getFinDemontage(expo) {
  const d = getDemontageRange(expo);
  return d ? d.end : (fixDate(expo.finissage)
    ? new Date(fixDate(expo.finissage).getTime() + 7 * 86400000)
    : new Date(0));
}

// ==================== RENDER ====================
function render() {
  const root     = document.getElementById('gantt-root');
  const filtered = getFilteredExpos();
  if (filtered.length === 0)
    return root.innerHTML = '<div class="no-data"><h2>?? AUCUNE EXPOSITION</h2></div>';

  let minD = Infinity, maxD = -Infinity;
  filtered.forEach(e => {
    [getMontageRange(e)?.start, getMontageRange(e)?.end,
     getDemontageRange(e)?.start, getDemontageRange(e)?.end,
     fixDate(e.vernissage), fixDate(e.finissage)].forEach(dt => {
      if (dt) { if (dt < minD) minD = dt; if (dt > maxD) maxD = dt; }
    });
  });

  rangeStart = new Date(minD); rangeStart.setDate(rangeStart.getDate() - 14);
  const rangeEnd   = new Date(maxD); rangeEnd.setDate(rangeEnd.getDate() + 30);
  const totalDays  = daysBetween(rangeStart, rangeEnd);
  const totalWidth = totalDays * dayWidth;

  const days = [];
  for (let i = 0; i < totalDays; i++) {
    const d = new Date(rangeStart.getTime() + i * 86400000);
    days.push({
      d,
      isWE:        d.getDay() === 0 || d.getDay() === 6,
      isGlobalFer: isFerieGlobal(d),
      isToday:     daysBetween(d, new Date()) === 0,
      i
    });
  }

  const workloadCounts = new Array(totalDays).fill(0);
  if (showWorkload) {
    filtered.forEach(expo => {
      if (expo.Pret === true || expo.Pret === 'true') return;
      const m = getMontageRange(expo), dem = getDemontageRange(expo);
      days.forEach(({ d, i }) => {
        const t = d.getTime();
        if (m   && t >= m.start.getTime()   && t <= m.end.getTime())   workloadCounts[i]++;
        if (dem && t >= dem.start.getTime() && t <= dem.end.getTime()) workloadCounts[i]++;
      });
    });
  }
  const maxWorkload = Math.max(...workloadCounts, 1);

  const groups = {};
  filtered.forEach(e => {
    let lId  = e.Musee || 0;
    const isP = e.Pret === true || e.Pret === 'true';
    if (isP) lId = 'PRET_GROUP';
    if (!groups[lId]) groups[lId] = { name: isP ? 'PRET' : getLieuName(lId), expos: [], isPret: isP };
    groups[lId].expos.push(e);
  });
  Object.values(groups).forEach(g => {
    g.expos.sort((a, b) =>
      (fixDate(a.vernissage) || new Date(0)) - (fixDate(b.vernissage) || new Date(0)));
  });
  const sortedKeys = Object.keys(groups).sort((a, b) => {
    if (a === 'PRET_GROUP') return 1;
    if (b === 'PRET_GROUP') return -1;
    return groups[a].name.localeCompare(groups[b].name);
  });

  let html = `<div class="gantt-wrapper"><div class="sticky-header" style="width:${totalWidth}px;">`;

  html += `<div class="month-header-bar">`;
  let cursor = new Date(rangeStart);
  while (cursor < rangeEnd) {
    const nextM = new Date(cursor.getFullYear(), cursor.getMonth() + 1, 1);
    const mEnd  = nextM < rangeEnd ? nextM : rangeEnd;
    const w     = daysBetween(cursor, mEnd) * dayWidth;
    html += `<div class="month-block" style="width:${w}px; min-width:${w}px;">
      ${w > 60 ? cursor.toLocaleDateString('fr-FR', { month: 'long', year: 'numeric' })
               : (w > 30 ? cursor.toLocaleDateString('fr-FR', { month: 'short' }) : '')}
    </div>`;
    cursor = nextM;
  }
  html += `</div>`;

  html += `<div class="days-header-bar">`;
  days.forEach(({ d, isWE, isGlobalFer, isToday }) => {
    let cls = 'day-cell';
    if (isToday)          cls += ' today-col';
    else if (isGlobalFer) cls += ' ferie';
    else if (isWE)        cls += ' weekend';
    const lbl = dayWidth >= 16
      ? `<b>${d.getDate()}</b><small>${JOURS[d.getDay()]}</small>`
      : (dayWidth >= 8 && d.getDate() % 5 === 1 ? `<b>${d.getDate()}</b>` : '');
    html += `<div class="${cls}" style="width:${dayWidth}px; min-width:${dayWidth}px;">${lbl}</div>`;
  });
  html += `</div>`;

  html += `<div class="workload-header-bar ${showWorkload ? 'visible' : ''}">`;
  days.forEach(({ i }) => {
    const count = workloadCounts[i];
    const pct   = count > 0 ? Math.round((count / maxWorkload) * 100) : 0;
    const bg    = count === 0 ? 'transparent'
                : (count >= 3 ? '#d63031' : count >= 2 ? '#e17055' : '#00b894');
    html += `<div class="workload-cell" style="width:${dayWidth}px; min-width:${dayWidth}px;">
      ${count > 0
        ? `<div class="workload-fill" style="height:${pct}%; background:${bg};"></div>
           ${dayWidth >= 12 ? `<span class="workload-text">${count}</span>` : ''}`
        : ''}
    </div>`;
  });
  html += `</div></div>`;

  html += `<div class="gantt-body" style="width:${totalWidth}px;">`;

  days.forEach(({ isWE, isGlobalFer, i }) => {
    if (isGlobalFer || isWE)
      html += `<div class="grid-col ${isGlobalFer ? 'ferie' : 'weekend'}"
        style="left:${i * dayWidth}px; width:${dayWidth}px;"></div>`;
  });

  const todayOff = daysBetween(rangeStart, new Date());
  if (todayOff >= 0 && todayOff <= totalDays)
    html += `<div class="today-line" style="left:${todayOff * dayWidth + dayWidth / 2}px;"></div>`;

  for (const gKey of sortedKeys) {
    const group = groups[gKey];
    const col   = collapsedGroups[gKey];

    html += `<div class="group-header" onclick="toggleGroup('${gKey}')">
      <div class="sticky-text">
        ${col ? '?' : '?'} ${group.isPret ? '??' : '???'} ${group.name}
        <span class="group-count">${group.expos.length}</span>
      </div>
    </div>`;

    if (!col) {
      html += `<div class="group-content">`;

      days.forEach(({ d, i }) => {
        const lf = getFerieForLieu(d, gKey);
        if (lf)
          html += `<div class="ferie-local-bg"
            style="left:${i * dayWidth}px; width:${dayWidth}px;"
            title="${lf.nom || 'F�ri� local'}"></div>`;
      });

      group.expos.forEach(expo => {
        const color      = getColorByCode(expo.CouleurEXPO);
        const m          = getMontageRange(expo);
        const dem        = getDemontageRange(expo);
        const v          = fixDate(expo.vernissage);
        const f          = fixDate(expo.finissage);
        const svcs       = getServices(expo);
        const badgesHtml = svcs.map(s => `<span class="svc-badge">${s}</span>`).join('');

        html += `<div class="expo-row">
          <div class="expo-label">${expo.Nom_de_l_exposition || 'Sans nom'}</div>`;

        if (!group.isPret) {
          if (m) {
            const lx = daysBetween(rangeStart, m.start) * dayWidth;
            const wx = Math.max(daysBetween(m.start, m.end) * dayWidth, dayWidth);
            html += `<div class="bar bar-montage"
              style="left:${lx}px; width:${wx}px; background:${color.dark};"
              onmouseenter="showTooltip(event,${expo.id})" onmouseleave="hideTooltip()"
              onclick="openEdit(${expo.id})">?? Montage ${badgesHtml}</div>`;
          }
          if (dem) {
            const lx = daysBetween(rangeStart, dem.start) * dayWidth;
            const wx = Math.max(daysBetween(dem.start, dem.end) * dayWidth, dayWidth);
            html += `<div class="bar bar-montage"
              style="left:${lx}px; width:${wx}px; background:${color.dark};"
              onmouseenter="showTooltip(event,${expo.id})" onmouseleave="hideTooltip()"
              onclick="openEdit(${expo.id})">?? D�montage ${badgesHtml}</div>`;
          }
        }
        if (v && f) {
          const lx = daysBetween(rangeStart, v) * dayWidth;
          const wx = Math.max(daysBetween(v, f) * dayWidth, dayWidth);
          html += `<div class="bar bar-expo"
            style="left:${lx}px; width:${wx}px; background:${color.light}; color:#2d3436;"
            onmouseenter="showTooltip(event,${expo.id})" onmouseleave="hideTooltip()"
            onclick="openEdit(${expo.id})">
            ${group.isPret ? '?? Pr�t' : '?? ' + (expo.Nom_de_l_exposition || 'Expo')}
            ${badgesHtml}</div>`;
        }
        html += `</div>`;
      });

      html += `</div>`;
    }
  }

  html += `</div></div>`;
  root.innerHTML = html;
}

function toggleGroup(id) {
  collapsedGroups[id] = !collapsedGroups[id];
  localStorage.setItem('gantt_collapsed', JSON.stringify(collapsedGroups));
  render();
}

function setZoom(val) {
  dayWidth = parseInt(val);
  document.getElementById('zoom-label').textContent = dayWidth + 'px';
  render();
}

function goToday() {
  if (!rangeStart) return;
  const cont = document.getElementById('container');
  cont.scrollTo({
    left: Math.max(0, daysBetween(rangeStart, new Date()) * dayWidth - cont.clientWidth / 2),
    behavior: 'smooth'
  });
}

